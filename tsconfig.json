{
    "compilerOptions": {

        "target": "esnext",
        "lib": ["dom", "dom.iterable", "esnext"],
        "allowJs": true,
        "skipLibCheck": true,
        "strict": true,
        "noEmit": true,
        "noImplicitAny": false,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "isolatedModules": true,
        "jsx": "preserve",
        "incremental": true,

        "plugins": [
            {
                "name": "next"
            }
        ],

        "typeRoots": [

            "./types",
            "./node_modules/@types"
        ],

        "paths": {

            "@/src/*": ["./src/*"],
            "@/app/*": ["./app/*"],
            "@/libs/*": ["./libs/*"],
            "@/components/*": ["./components/*"],
            "@/hooks/*": ["./hooks/*"],
            "@/stores/*": ["./stores/*"],
            "@/assets/*": ["./assets/*"]
        }
    },

    "include": [

        "**/*.ts",
        "**/*.tsx",
        "next-env.d.ts",
        ".next/types/**/*.ts",
        "public/.next/types/**/*.ts"
    ],

    "exclude": [

        "node_modules"
    ]
}
